# Copy this file to .env and fill in your values
# cp .env.example .env

# MongoDB Connection (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Render API Key (optional — only needed for Render deployment)
RENDER_API_KEY=

# Frontend URL (for CORS — set to your deployed frontend URL in production)
FRONTEND_URL=http://localhost:3000

# OpenRouter AI API Key (optional — only needed if AI features are enabled)
OPENROUTER_API_KEY=

# Stripe Keys (optional — only needed for billing features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary (optional — only needed for file upload features)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
